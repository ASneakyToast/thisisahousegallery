<style>
  .footer {
    --color-black: #222222;
    --color-teal: #00bfb3;
    --color-taupe: #efeee6;
    --color-white: #ffffff;

    --size-1: 8px;
    --size-2: 10px;
    --size-3: 20px;
    --size-4: 30px;
    --size-5: 40px;

    --text-color: var(--color-black);
    --text-spacing: var(--size-2);
    --text_size-small: var(--size-1);
    --text_size-medium: var(--size-2);

    --icon-size: var(--size-4);
    --icon-color: var(--color-teal);
    --icon-fill_color: var(--color-white);

    --logo-height: var(--size-4);

    --footer-background: var(--color-taupe);
    --footer-padding: var(--size-5);
  }

  .footer {
    padding: var(--footer-padding);
    background-color: var(--footer-background);
  }

  .footer__logo {
    height: var(--logo-height);

    /* temp until we can use image */
    width: 300px;
    background-color: gray;
  }

  .footer__social-link {
    border-radius: 100%;
    background-color: var(--color-teal); 
    width: var(--icon-size);
    height: var(--icon-size);
    padding: var(--size-1);
    box-sizing: border-box;
  }
  .footer__social-link svg {
    fill: var(--color-white);
    height: 100%;
    width: 100%;
  }

  .footer__land-ack,
  .footer__mailing-address, 
  .footer__copyright {
    color: var(--text-color);
    padding: var(--text-spacing) 0;
  }

  .footer__land-ack,
  .footer__copyright {
    font-size: var(--text_size-small);
  }

  .footer__mail-address {
    font-size: var(--text_size-medium);
  }

  hr {
    color: var(--text-color);
  }
</style>
