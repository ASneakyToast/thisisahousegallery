---
const { img_src, img_alt, link, heading, subheading } = Astro.props
---
<section class="homepage-tableau">
  <img class="homepage-tableau__image" src={ img_src } alt={ img_alt }></img>
  <a href={ link }>
    <section class="homepage-tableau__details">
      <h2><i>{ heading }</i></h2>
      <h3>{ subheading }</h3>
    </section>
  </a>
</section>

<style lang="scss">
  .homepage-tableau {
    position: relative;
    height: 100%;

    &__image {
      width: 100%;
      height: 700px;
      object-fit: cover;
      height: 100%;
    }

    &__details {
      position: absolute;
      bottom: var(--space-base-huge);
      right: var(--space-base-huge);
      padding: var(--space-base-tiny) var(--space-base-large);
      background-color: white;

      & h2 {
        font-family: var(--font-secondary);
        color: var(--color-main-primary);
        text-decoration: none;
        font-weight: lighter;
      }

      & h3 {
        font-weight: lighter;
      }

      &:hover {
        color: var(--color-base-white);;
        cursor: var(--cursor-main--hover);
        background-color: var(--color-main-primary);
       
        & h2 {
          color: inherit;
          text-decoration: underline;
        }
      }
    }
  }
</style>
