---
const { image_url, alt_text, caption } = Astro.props;
---

<section class="image_with_quickview">
  <img src={ image_url } alt={ alt_text }></img>
</section>

<script define:vars={{ image_url, alt_text, caption }}>
  const image_with_quickview_items = document.querySelectorAll( ".image_with_quickview" );
  const quickview_simple = document.querySelector( ".quickview_simple" );

  image_with_quickview_items.forEach(( image ) => {
    image.addEventListener( "click", () => {
      console.log( "alert" );

      // Send Data
      const quickviewEvent = new CustomEvent( "quickview-simple--open", {
        // bubbles: true,
        detail: {
          image_url: image_url,
          alt_text: alt_text,
          caption: caption,
        }
      });
      console.log( quickviewEvent );
      quickview_simple.dispatchEvent( quickviewEvent );
      /*
      this.dispatchEvent( quickviewEvent );
      */
    });
  });
</script>

<style scoped lang="scss">
  .image_with_quickview {

    &:hover {
      cursor: pointer;
    }
  }
</style>
