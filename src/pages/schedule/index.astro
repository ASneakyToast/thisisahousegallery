---
import Layout from "../../layouts/Layout.astro";
import ExhibitionItem from "../../components/exhibition-listing.astro";
---

<Layout title="Schedule | House Gallery">
  <main class="layout">
    <section class="main-feature">

      <ExhibitionItem 
         title="Your Least Fav Work"
         artists="Open Call Group Show"
         date="Party August 18th"
         link="/schedule/yourleastfavwork"
         open_call_url="https://docs.google.com/forms/d/e/1FAIpQLSeAXU7XeqjlyWrvz3lx5VZRW4_Mq9wbQUJO6D8WE7V3iyIVvg/viewform?usp=sf_link"
         google_cal_invite_url="https://calendar.google.com/calendar/event?action=TEMPLATE&tmeid=MWtmbTBmdDVkbWsyNjQ4N2M4NWFjajN2aTggdGhpc2lzYWhvdXNlZ2FsbGVyeUBt&tmsrc=thisisahousegallery%40gmail.com"
         cta="true"
         cta_label="Submit Work"
         cta_tooltip="Send it"
         cta_url="https://docs.google.com/forms/d/e/1FAIpQLSeAXU7XeqjlyWrvz3lx5VZRW4_Mq9wbQUJO6D8WE7V3iyIVvg/viewform?usp=sf_link"
         img_url="/exhibitions/yourleastfavoritework/Showcard001.jpg"
         img_alt="The promotional showcard for the exhibition 'Your Least Fav Work' with This is a House Gallery."
         featured="true" />

      <ExhibitionItem 
         title="Tablets, Tables & Tombstones"
         artists="Annie Artell, Sophie Smith, Dareal Calderon"
         date="??? - ???"
         cta="false"
         featured="false" />

    </section>

    <!--
    <section class="main-aside">
      <a class="cta" target="_blank" href="https://docs.google.com/forms/d/e/1FAIpQLSeAXU7XeqjlyWrvz3lx5VZRW4_Mq9wbQUJO6D8WE7V3iyIVvg/viewform?usp=sf_link">
        <h2>Open Call</h2>
        <img></img>
      </a>
    </section>
    -->

    <section id="social" class="main-bottom">
      <h2>Follow us</h2>
      <a target="_blank" href="https://www.instagram.com/thisisahousegallery/">
        <h3>@Thisisahousegallery</h3>
      </a>
    </section>
  </main>
</Layout>

<style lang="scss">

	main {
		margin: auto;
    padding: var(--space-base-huge) var(--space-base-large) var(--space-base-large) var(--space-base-large);
    max-width: 1024px;

    @media (max-width: 675px) {
      padding: var(--space-base-medium) var(--space-base-small) var(--space-base-small) var(--space-base-small);
    }

    @media (max-width: 1024px) {
      padding: var(--space-base-large) var(--space-base-medium) var(--space-base-medium) var(--space-base-medium);
    }
	}

  .layout {
    display: grid;
    grid-template-areas:
      "header header"
      "feature aside"
      "bottom bottom";
    grid-template-columns: 3fr 1fr;

    @media (max-width: 1024px) {
      grid-template-areas:
        "header"
        "feature"
        "aside"
        "bottom";
    }
  }

  .head {
    grid-area: header;
    justify-self: right;
    text-align: right;
  }
  .main-feature {
    grid-area: feature;
    width: fit-content;
    display: flex;
    flex-direction: column;
    gap: var(--space-base-large);

    @media (max-width: 675px) {
      padding: 0;
    }
  }

  .main-aside {
    grid-area: aside;
    padding: 32px 0;
    position: sticky;
    top: 350px;
    height: fit-content;
    z-index: 4;
    @media (max-width: 1024px) {
      position: relative;
      top: 0;
      justify-self: right;
      text-align: right;
    }
  }

  .main-bottom {
    grid-area: bottom;
    margin-top: 64px;

    h2 {
      color: black;
      align-self: right;
      font-weight: lighter;
      font-size: var(--font_size-small);
    }

    h3 {
      color: var(--color-main-primary);
      font-family: var(--font-secondary);
      font-weight: lighter;
    }
  }

	.head h1 {
		font-size: 16px;
		font-weight: 800;
		margin: 0;
	}
  .head p {
    font-size: 12px;
  }
  .head a {
    color: black;
    text-decoration: none;
  }
  .head a:hover {
    color: var(--color-main-primary);
    text-decoration: underline;
  }

  .head-nav {
    display: flex;
    flex-direction: row;
    gap: 8px;
    justify-content: right;
  }
  .head-nav a {
    text-decoration: underline;
    color: var(--color-main-primary);
  }

  .main-aside h2 {
    color: var(--color-main-primary);
    font-family: var(--font-secondary);
    font-weight: lighter;
  }
  .main-aside img {
    width: 200px;
    height: 200px;
    background-color: lightgray;
  }
</style>
