<style lang="scss">
  @mixin marching-ants-v2-init($ant-size,$ant-width,$speed,$id){
    padding: 5px + $ant-width;
    margin: 20px;
    background-size:
      $ant-size $ant-width,
      $ant-size $ant-width,
      $ant-width $ant-size,
      $ant-width $ant-size;
    background-position:
      0 0,
      0 100%,
      0 0,
      100% 0;
    background-repeat:
      repeat-x,
      repeat-x,
      repeat-y,
      repeat-y;
    animation: marching-ants-#{$id} $speed;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-play-state: paused;
    &:hover, &.marching {
      animation-play-state: running;
    }
    &.reverse {
      animation-direction: reverse;
    }
  };
  @mixin marching-ants-v2-color($a, $b){
      background-image:
        linear-gradient(to right, $a 50%, $b 50%),
        linear-gradient(to right, $a 50%, $b 50%),
        linear-gradient(to bottom, $a 50%, $b 50%),
        linear-gradient(to bottom, $a 50%, $b 50%);
  };

  @mixin marching-ants-v2-animation($ant-size, $id){
    @keyframes marching-ants-#{$id} {
      0% {
        background-position:
          0 0,
          0 100%,
          0 0,
          100% 0;
      }
      100% {
        background-position:
          2*$ant-size 0,
          -2*$ant-size 100%,
          0 -2*$ant-size,
          100% 2*$ant-size;
      }
    }
  }

	main {
		margin: auto;
    padding: var(--space-base-huge) var(--space-base-large) var(--space-base-large) var(--space-base-large);
    max-width: 1024px;

    @media (max-width: 675px) {
      padding: var(--space-base-medium) var(--space-base-small) var(--space-base-small) var(--space-base-small);
    }

    @media (max-width: 1024px) {
      padding: var(--space-base-large) var(--space-base-medium) var(--space-base-medium) var(--space-base-medium);
    }
	}

  .layout {
    display: grid;
    grid-template-areas:
      "header header"
      "feature aside"
      "bottom none";
    grid-template-columns: 3fr 1fr;

    @media (max-width: 1024px) {
      grid-template-areas:
        "header"
        "feature"
        "aside"
        "bottom";
    }
  }

  .head {
    grid-area: header;
    justify-self: right;
    text-align: right;
  }
  .main-feature {
    grid-area: feature;
    width: fit-content;
    display: flex;
    flex-direction: column;
    gap: var(--space-base-large);

    margin-top: 32px;
    margin-bottom: var(--space-base-ginormous);

    @media (max-width: 675px) {
      padding: 0;
    }
  }

  .main-aside {
    grid-area: aside;
    padding: 32px 0;
    position: sticky;
    top: 350px;
    height: fit-content;
    z-index: 4;
    @media (max-width: 1024px) {
      position: relative;
      top: 0;
      justify-self: right;
      text-align: right;
    }
  }

  .main-bottom {
    grid-area: bottom;
    padding: var(--space-base-small) var(--space-base-medium) !important;
    margin: 0 !important;
    margin-top: 64px;

    h2 {
      color: black;
      align-self: right;
      font-weight: lighter;
      font-size: var(--font_size-small);
    }
    h3 {
      color: var(--color-main-primary);
      font-family: var(--font-secondary);
      font-weight: 700;
      text-decoration: underline;
    }

    @include marching-ants-v2-init(20px, 8px, 4s, 415243);
    @include marching-ants-v2-color(#111,#fff);
  }
  @include marching-ants-v2-animation(20px, 415243);

	.head h1 {
		font-size: 16px;
		font-weight: 800;
		margin: 0;
	}
  .head p {
    font-size: 12px;
  }
  .head a {
    color: black;
    text-decoration: none;
  }
  .head a:hover {
    color: var(--color-main-primary);
    text-decoration: underline;
  }

  .head-nav {
    display: flex;
    flex-direction: row;
    gap: 8px;
    justify-content: right;
  }
  .head-nav a {
    text-decoration: underline;
    color: var(--color-main-primary);
  }

  .main-aside h2 {
    color: var(--color-main-primary);
    font-family: var(--font-secondary);
    font-weight: lighter;
  }
  .main-aside img {
    width: 200px;
    height: 200px;
    background-color: lightgray;
  }
</style>
