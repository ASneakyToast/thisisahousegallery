---
import Layout from "../../layouts/Layout.astro";

const title = "Your Least Favorite Work | House Gallery";

const header = "Your Least Fav Work";
const artists = "Open Call";
const date="Party August 18th";
const open_call_url="https://docs.google.com/forms/d/e/1FAIpQLSeAXU7XeqjlyWrvz3lx5VZRW4_Mq9wbQUJO6D8WE7V3iyIVvg/viewform?usp=sf_link"
const google_cal_invite_url="https://calendar.google.com/calendar/event?action=TEMPLATE&tmeid=MWtmbTBmdDVkbWsyNjQ4N2M4NWFjajN2aTggdGhpc2lzYWhvdXNlZ2FsbGVyeUBt&tmsrc=thisisahousegallery%40gmail.com"
---

<Layout title={ title }>
  <main class="layout">
    <section class="layout-main">
      <section class="info"> 
        <h1>{ header }</h1>
      <hr></hr>
      { google_cal_invite_url ?
        <h2>> <a target="_blank" href={ google_cal_invite_url }>{ date }</a></h2>
        :
        <h2>> { date }</h2>
      }
      { open_call_url ?
        <h3>> <a target="_blank" href={ open_call_url }>{ artists }</a></h3>
        :
        <h3>> { artists }</h3>
      }
      </section>

      <section class="description">
        <p>An open call show where artists submitted their least favorite artwork. Come see everything that was in a storage box now in a bigger box we call our living room.</p>
      </section>
    </section>

    </section>
    <section class="layout-aside">
      <section class="images">
        <img src="/exhibitions/yourleastfavoritework/Showcard001.jpg" alt="A zoomed in view of the promotional showcard for the exhibition 'Your Least Fav Work' by This is a House Gallery."></img>
        <img src="/exhibitions/yourleastfavoritework/Showcard-back.jpg" alt="A zoomed in view of the promotional showcard for the exhibition 'Your Least Fav Work' by This is a House Gallery."></img>
      </section>
    </section>
  </main>
</Layout>

<style lang="scss">

  /* Guess I gotta do this everywhere until I refactor the layout */
  main {
    margin: auto;
    padding: var(--space-base-huge) var(--space-base-large) var(--space-base-large) var(--space-base-large);
    max-width: 1024px;

    @media (max-width: 675px) {
      padding: var(--space-base-medium) var(--space-base-small) var(--space-base-small) var(--space-base-small);
    }

    @media (max-width: 1024px) {
      padding: var(--space-base-large) var(--space-base-medium) var(--space-base-medium) var(--space-base-medium);
    }

    & h1 {
      font-size: 2rem;
      font-weight: lighter;
    }
    & h2 {
      font-size: 1.17rem;
      font-weight: lighter;
    }
    & h3 {
      font-size: 1rem;
      font-weight: lighter;
    }
    & p {
      font-weight: lighter;
    }

    & hr {
      margin: var(--space-base-large) 0;
    }
  }

  .layout {
    display: grid;
    grid-template-areas:
      "main" "aside";
    grid-template-columns: 3fr 1fr;
    gap: var(--space-base-huge);

    @media (max-width: 1024px) {
      grid-template-areas:
        "header"
        "aside";
    }
  }

  .info {
  }


  .description {
    width: 75%;
  }

  .images {
    & img {
      margin-bottom: var(--space-base-small);
    }
  }

</style>
