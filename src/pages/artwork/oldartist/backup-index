---
import artwork_database from "../../../data/artwork-database.json";
import { slugify } from "../../../utils/basic-javascript";
import Layout from "../../../layouts/Layout.astro";

// Create pages
export function getStaticPaths() {

  // Get unique list of artist names
  let every_frickin_artist = [];
  artwork_database.forEach( artwork => {
    every_frickin_artist.push( artwork["Artist"] );  
  });
  let unique_artist_list = [...new Set(every_frickin_artist)];

  // Turn list into slugified params
  let all_params = [];
  unique_artist_list.forEach( artist_name => {
    all_params.push({
      params: {artist: slugify(artist_name)}
    })
  })

  return all_params;
}

const { artist } = Astro.params;

// Get artwork related to artist
const artwork = artwork_database.filter( item => {
  return (
    item.artist == artist
  )
});
---

