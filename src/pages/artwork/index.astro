---
import * as db from "../../utils/db-handler.js";
import * as image_db from "../../utils/image-db-handler.js";
import Layout from "../../layouts/Layout.astro";
import { Image } from 'astro:assets';
import { slugify, shuffle } from "../../utils/basic-javascript.js";

let artworks = db.get_all_artwork();
artworks = shuffle( artworks );

const processed_images = import.meta.glob("/src/media/exhibition-images/*.{jpeg,jpg,png,gif}");
---

<Layout title="House Gallery | Artwork" type="normal">
  <main>
    <section class="page-info">
      <h1 class="page-info__title">Artwork</h1>
      <h2 class="page-info__subtitle">Everything that has been shown in this living room.</h2>
    </section>

    <section class="page-images">
      { artworks.map( artwork => (
        <a href={`/artwork/${ slugify(artwork["Artist"]) }/${ slugify(artwork["ID"]) }`}>
          <Image 
            class="quickview-item" 
            src={ processed_images[`/src/media/exhibition-images/${artwork.Cover.photo[0].filename}`]() }
            alt="" 
            width=200
            height=200
          />
        </a>
      ))}
    </section>
  </main>
</Layout>

<style lang="scss">
  main {
    display: grid;
    grid-template-columns: 3fr 5fr;
    gap: var(--space-section-gap);
  }

  .page-images {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-item-gap);

    & img {
      aspect-ratio: 1/1;
      object-fit: cover;
      width: 100px;
      height: 100px;
    }
  }

  .page-info {
    &__title {
      font-size: 20px;
      letter-spacing: 20px;
      text-transform: uppercase;
      font-weight: 700;

      margin-top: 0;
    }

    &__subtitle {
      font-size: var(--font_size-medium);
      margin-bottom: var(--space-base-medium);
    }
  }
</style>
